{
  "name": "screenconnect-frontend",
  "version": "1.0.0",
  "description": "ScreenConnect Session Downloader Frontend",
  "main": "index.html",
  "scripts": {
    "dev": "npm run serve:dev",
    "serve:dev": "http-server src -p 3000 -o",
    "start": "npm run dev",
    "serve": "http-server src -p 8080",
    "build": "echo 'No build needed - using Tailwind CDN'",
    "build:css": "echo 'CSS build skipped - using Tailwind CDN'",
    "build:css:watch": "echo 'CSS watch skipped - using Tailwind CDN'",
    "dev:watch": "npm run serve:dev",
    "deploy": "echo 'Deploy src/ directory to your static hosting provider'"
  },
  "keywords": [
    "screenconnect",
    "static-site",
    "tailwind",
    "frontend"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "http-server": "^14.1.1",
    "tailwindcss": "^3.4.0",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.32"
  },
  "engines": {
    "node": ">=14.0.0"
  }
} 